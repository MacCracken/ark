fn acfg_confirm_rm(p) { return load64(p + 16); }
fn acfg_auto_update(p) { return load64(p + 24); }
fn acfg_color(p) { return load64(p + 32); }
fn acfg_set_color(p, v) { store64(p + 32, v); }
