# ark - Unified Package Manager CLI for AGNOS
# Ported from 4363 lines of Rust
#
# ark is the user-facing CLI for AGNOS package management. It translates
# user commands into operations, using the nous resolver to figure out where
# packages come from (system apt, marketplace agents, or Flutter app bundles),
# then produces execution plans that callers can run with appropriate
# permissions via shakti.
#
# ark does NOT directly execute apt-get or dpkg. It generates InstallPlan
# instructions - a deliberate security design choice.

# Stdlib auto-included via cyrius.cyml

# =========================================================================
# Constants
# =========================================================================

var ARK_VERSION_STR = "0.1.0";

var DEFAULT_TRANSACTION_LOG_PATH = "/var/lib/agnos/ark/transaction.log";
var DEFAULT_PACKAGE_DB_PATH = "/var/lib/agnos/ark/packages.json";

# ANSI color codes
var ANSI_RESET = "\x1b[0m";
var ANSI_BOLD = "\x1b[1m";
var ANSI_GREEN = "\x1b[32m";
var ANSI_RED = "\x1b[31m";
var ANSI_YELLOW = "\x1b[33m";
var ANSI_CYAN = "\x1b[36m";

# =========================================================================
# PackageSource enum (from nous - stubbed here until nous is ported)
# =========================================================================

enum PackageSource {
    SOURCE_SYSTEM = 0;
    SOURCE_MARKETPLACE = 1;
    SOURCE_FLUTTER_APP = 2;
    SOURCE_COMMUNITY = 3;
    SOURCE_UNKNOWN = 4;
}

fn source_to_str(src) {
    if (src == SOURCE_SYSTEM) { return "system"; }
    if (src == SOURCE_MARKETPLACE) { return "marketplace"; }
    if (src == SOURCE_FLUTTER_APP) { return "flutter-app"; }
    if (src == SOURCE_COMMUNITY) { return "community"; }
    return "unknown";
}

fn parse_source_str(s) {
    if (streq(s, "system")) { return Ok(SOURCE_SYSTEM); }
    if (streq(s, "apt")) { return Ok(SOURCE_SYSTEM); }
    if (streq(s, "marketplace")) { return Ok(SOURCE_MARKETPLACE); }
    if (streq(s, "market")) { return Ok(SOURCE_MARKETPLACE); }
    if (streq(s, "flutter")) { return Ok(SOURCE_FLUTTER_APP); }
    if (streq(s, "flutter-app")) { return Ok(SOURCE_FLUTTER_APP); }
    if (streq(s, "flutterapp")) { return Ok(SOURCE_FLUTTER_APP); }
    return Err(1);
}

# =========================================================================
# ResolutionStrategy enum (from nous - stubbed)
# =========================================================================

enum ResolutionStrategy {
    STRATEGY_MARKETPLACE_FIRST = 0;
    STRATEGY_SYSTEM_FIRST = 1;
    STRATEGY_ONLY_SOURCE = 2;
    STRATEGY_SEARCH_ALL = 3;
}

fn strategy_to_str(s) {
    if (s == STRATEGY_MARKETPLACE_FIRST) { return "MarketplaceFirst"; }
    if (s == STRATEGY_SYSTEM_FIRST) { return "SystemFirst"; }
    if (s == STRATEGY_ONLY_SOURCE) { return "OnlySource"; }
    if (s == STRATEGY_SEARCH_ALL) { return "SearchAll"; }
    return "Unknown";
}

# =========================================================================
# ArkCommand - tagged struct with accessors
# Fields: tag(0) packages(8) query(16) group(24) package(32) source(40)
#         force(48) purge(56) count(64)   => 72 bytes
# =========================================================================

enum ArkCommandTag {
    CMD_INSTALL = 0;
    CMD_GROUP_INSTALL = 1;
    CMD_REMOVE = 2;
    CMD_SEARCH = 3;
    CMD_LIST = 4;
    CMD_INFO = 5;
    CMD_UPDATE = 6;
    CMD_UPGRADE = 7;
    CMD_STATUS = 8;
    CMD_HOLD = 9;
    CMD_UNHOLD = 10;
    CMD_VERIFY = 11;
    CMD_HISTORY = 12;
}

var ACMD_SZ = 72;

fn acmd_tag(p) { return load64(p); }
fn acmd_set_tag(p, v) { store64(p, v); }
fn acmd_packages(p) { return load64(p + 8); }
fn acmd_set_packages(p, v) { store64(p + 8, v); }
fn acmd_query(p) { return load64(p + 16); }
fn acmd_set_query(p, v) { store64(p + 16, v); }
fn acmd_group(p) { return load64(p + 24); }
fn acmd_set_group(p, v) { store64(p + 24, v); }
fn acmd_package(p) { return load64(p + 32); }
fn acmd_set_package(p, v) { store64(p + 32, v); }
fn acmd_source(p) { return load64(p + 40); }
fn acmd_set_source(p, v) { store64(p + 40, v); }
fn acmd_force(p) { return load64(p + 48); }
fn acmd_set_force(p, v) { store64(p + 48, v); }
fn acmd_purge(p) { return load64(p + 56); }
fn acmd_set_purge(p, v) { store64(p + 56, v); }
fn acmd_count(p) { return load64(p + 64); }
fn acmd_set_count(p, v) { store64(p + 64, v); }

fn ark_cmd_new(tag) {
    var p = alloc(ACMD_SZ);
    acmd_set_tag(p, tag);
    acmd_set_packages(p, vec_new());
    acmd_set_query(p, str_from(""));
    acmd_set_group(p, str_from(""));
    acmd_set_package(p, str_from(""));
    acmd_set_source(p, 0 - 1);
    acmd_set_force(p, 0);
    acmd_set_purge(p, 0);
    acmd_set_count(p, 0 - 1);
    return p;
}

# =========================================================================
# ArkOutputLine
# Fields: tag(0) text(8) name(16) version(24) source(32) description(40)
#         key(48) value(56)   => 64 bytes
# =========================================================================

enum OutputLineTag {
    LINE_HEADER = 0;
    LINE_PACKAGE = 1;
    LINE_INFO = 2;
    LINE_SEPARATOR = 3;
    LINE_SUCCESS = 4;
    LINE_ERROR = 5;
    LINE_WARNING = 6;
}

var OLINE_SZ = 64;

fn oline_tag(p) { return load64(p); }
fn oline_text(p) { return load64(p + 8); }
fn oline_name(p) { return load64(p + 16); }
fn oline_version(p) { return load64(p + 24); }
fn oline_source(p) { return load64(p + 32); }
fn oline_desc(p) { return load64(p + 40); }
fn oline_key(p) { return load64(p + 48); }
fn oline_value(p) { return load64(p + 56); }

fn output_line_header(text) {
    var p = alloc(OLINE_SZ);
    store64(p, LINE_HEADER);
    store64(p + 8, text);
    return p;
}

fn output_line_package(name, version, source, description) {
    var p = alloc(OLINE_SZ);
    store64(p, LINE_PACKAGE);
    store64(p + 16, name);
    store64(p + 24, version);
    store64(p + 32, source);
    store64(p + 40, description);
    return p;
}

fn output_line_info(key, value) {
    var p = alloc(OLINE_SZ);
    store64(p, LINE_INFO);
    store64(p + 48, key);
    store64(p + 56, value);
    return p;
}

fn output_line_separator() {
    var p = alloc(OLINE_SZ);
    store64(p, LINE_SEPARATOR);
    return p;
}

fn output_line_success(text) {
    var p = alloc(OLINE_SZ);
    store64(p, LINE_SUCCESS);
    store64(p + 8, text);
    return p;
}

fn output_line_error(text) {
    var p = alloc(OLINE_SZ);
    store64(p, LINE_ERROR);
    store64(p + 8, text);
    return p;
}

fn output_line_warning(text) {
    var p = alloc(OLINE_SZ);
    store64(p, LINE_WARNING);
    store64(p + 8, text);
    return p;
}

# =========================================================================
# ArkOutput - vec of ArkOutputLine
# =========================================================================

fn ark_output_new() { return vec_new(); }
fn ark_output_add(out, line) { vec_push(out, line); }

fn ark_output_to_display_string(output) {
    var sb = str_builder_new();
    var i = 0;
    var len = vec_len(output);
    while (i < len) {
        var ln = vec_get(output, i);
        var t = oline_tag(ln);
        if (t == LINE_HEADER) {
            str_builder_add_cstr(sb, "=== ");
            str_builder_add(sb, oline_text(ln));
            str_builder_add_cstr(sb, " ===\n");
        }
        if (t == LINE_PACKAGE) {
            str_builder_add_cstr(sb, "  ");
            str_builder_add(sb, oline_name(ln));
            str_builder_add_cstr(sb, " (");
            str_builder_add(sb, oline_version(ln));
            str_builder_add_cstr(sb, ") [");
            str_builder_add_cstr(sb, source_to_str(oline_source(ln)));
            str_builder_add_cstr(sb, "] -- ");
            str_builder_add(sb, oline_desc(ln));
            str_builder_add_cstr(sb, "\n");
        }
        if (t == LINE_INFO) {
            str_builder_add_cstr(sb, "  ");
            str_builder_add(sb, oline_key(ln));
            str_builder_add_cstr(sb, ": ");
            str_builder_add(sb, oline_value(ln));
            str_builder_add_cstr(sb, "\n");
        }
        if (t == LINE_SEPARATOR) { str_builder_add_cstr(sb, "---\n"); }
        if (t == LINE_SUCCESS) {
            str_builder_add_cstr(sb, "OK: ");
            str_builder_add(sb, oline_text(ln));
            str_builder_add_cstr(sb, "\n");
        }
        if (t == LINE_ERROR) {
            str_builder_add_cstr(sb, "ERROR: ");
            str_builder_add(sb, oline_text(ln));
            str_builder_add_cstr(sb, "\n");
        }
        if (t == LINE_WARNING) {
            str_builder_add_cstr(sb, "WARN: ");
            str_builder_add(sb, oline_text(ln));
            str_builder_add_cstr(sb, "\n");
        }
        i = i + 1;
    }
    return str_builder_build(sb);
}

fn ark_output_to_colored_string(output) {
    var sb = str_builder_new();
    var i = 0;
    var len = vec_len(output);
    while (i < len) {
        var ln = vec_get(output, i);
        var t = oline_tag(ln);
        if (t == LINE_HEADER) {
            str_builder_add_cstr(sb, ANSI_BOLD);
            str_builder_add_cstr(sb, "=== ");
            str_builder_add(sb, oline_text(ln));
            str_builder_add_cstr(sb, " ===");
            str_builder_add_cstr(sb, ANSI_RESET);
            str_builder_add_cstr(sb, "\n");
        }
        if (t == LINE_PACKAGE) {
            str_builder_add_cstr(sb, "  ");
            str_builder_add_cstr(sb, ANSI_CYAN);
            str_builder_add(sb, oline_name(ln));
            str_builder_add_cstr(sb, ANSI_RESET);
            str_builder_add_cstr(sb, " (");
            str_builder_add(sb, oline_version(ln));
            str_builder_add_cstr(sb, ") [");
            str_builder_add_cstr(sb, source_to_str(oline_source(ln)));
            str_builder_add_cstr(sb, "] -- ");
            str_builder_add(sb, oline_desc(ln));
            str_builder_add_cstr(sb, "\n");
        }
        if (t == LINE_INFO) {
            str_builder_add_cstr(sb, "  ");
            str_builder_add_cstr(sb, ANSI_BOLD);
            str_builder_add(sb, oline_key(ln));
            str_builder_add_cstr(sb, ANSI_RESET);
            str_builder_add_cstr(sb, ": ");
            str_builder_add(sb, oline_value(ln));
            str_builder_add_cstr(sb, "\n");
        }
        if (t == LINE_SEPARATOR) { str_builder_add_cstr(sb, "---\n"); }
        if (t == LINE_SUCCESS) {
            str_builder_add_cstr(sb, ANSI_GREEN);
            str_builder_add_cstr(sb, "OK: ");
            str_builder_add(sb, oline_text(ln));
            str_builder_add_cstr(sb, ANSI_RESET);
            str_builder_add_cstr(sb, "\n");
        }
        if (t == LINE_ERROR) {
            str_builder_add_cstr(sb, ANSI_RED);
            str_builder_add_cstr(sb, "ERROR: ");
            str_builder_add(sb, oline_text(ln));
            str_builder_add_cstr(sb, ANSI_RESET);
            str_builder_add_cstr(sb, "\n");
        }
        if (t == LINE_WARNING) {
            str_builder_add_cstr(sb, ANSI_YELLOW);
            str_builder_add_cstr(sb, "WARN: ");
            str_builder_add(sb, oline_text(ln));
            str_builder_add_cstr(sb, ANSI_RESET);
            str_builder_add_cstr(sb, "\n");
        }
        i = i + 1;
    }
    return str_builder_build(sb);
}

fn ark_output_render(output, color) {
    if (color) { return ark_output_to_colored_string(output); }
    return ark_output_to_display_string(output);
}

# =========================================================================
# InstallStep
# Fields: tag(0) package(8) version(16) purge(24)   => 32 bytes
# =========================================================================

enum InstallStepTag {
    STEP_SYSTEM_INSTALL = 0;
    STEP_SYSTEM_REMOVE = 1;
    STEP_MARKETPLACE_INSTALL = 2;
    STEP_MARKETPLACE_REMOVE = 3;
    STEP_FLUTTER_INSTALL = 4;
    STEP_FLUTTER_REMOVE = 5;
    STEP_SYSTEM_UPDATE = 6;
}

var ISTEP_SZ = 32;

fn istep_tag(p) { return load64(p); }
fn istep_pkg(p) { return load64(p + 8); }
fn istep_ver(p) { return load64(p + 16); }
fn istep_purge(p) { return load64(p + 24); }

fn step_new(tag, pkg, ver, purge) {
    var p = alloc(ISTEP_SZ);
    store64(p, tag);
    store64(p + 8, pkg);
    store64(p + 16, ver);
    store64(p + 24, purge);
    return p;
}

fn step_system_install(pkg, ver) { return step_new(STEP_SYSTEM_INSTALL, pkg, ver, 0); }
fn step_system_remove(pkg, purge) { return step_new(STEP_SYSTEM_REMOVE, pkg, str_from(""), purge); }
fn step_marketplace_install(pkg, ver) { return step_new(STEP_MARKETPLACE_INSTALL, pkg, ver, 0); }
fn step_marketplace_remove(pkg) { return step_new(STEP_MARKETPLACE_REMOVE, pkg, str_from(""), 0); }
fn step_flutter_install(pkg, ver) { return step_new(STEP_FLUTTER_INSTALL, pkg, ver, 0); }
fn step_flutter_remove(pkg) { return step_new(STEP_FLUTTER_REMOVE, pkg, str_from(""), 0); }
fn step_system_update() { return step_new(STEP_SYSTEM_UPDATE, str_from(""), str_from(""), 0); }

