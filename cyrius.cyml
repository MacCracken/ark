[package]
name = "ark"
version = "0.8.0"
description = "ark - Cyrius port"
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "5.1.8"

[build]
entry = "src/main.cyr"
output = "ark"
defines = ["ARK_MAIN"]

[deps]
stdlib = ["string", "fmt", "alloc", "vec", "str", "syscalls", "io", "args", "assert", "hashmap", "tagged", "toml", "json", "fs", "fnptr", "callback", "bench", "regex", "freelist", "bigint", "chrono"]

[deps.sigil]
path = "../sigil"
modules = ["dist/sigil.cyr"]
